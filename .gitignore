# ============================================================
# QUANT PLATFORM — .gitignore
# ============================================================

# ---- Claude Code agent scratchpads (local only) ----
.claude/worktrees/
.claude/sessions/
.claude/history.jsonl
.claude/todos/

# ---- Secrets ----
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials/

# ---- OS ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
*.egg-info/
*.egg
dist/
build/
pip-wheel-metadata/

# ---- Node / Next.js ----
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts
.pnpm-store/

# ---- Data (tracked via DVC / MinIO, not git) ----
data/raw/*
data/processed/*
data/legacy/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/legacy/.gitkeep
*.parquet
*.feather

# ---- Backtest example derived artifacts ----
# The adapted CSV is large (~30MB) and regenerable from data/legacy/.
apps/api/examples/backtest/sp500_5yr_adjusted.csv
# Synced into the web Docker build context by `npm run sync-artifacts`.
apps/web/.oracle-artifacts/
# Daily-cron-produced files are tracked so Vercel rebuilds pick them up.
!apps/web/.oracle-artifacts/paper-status.json
!apps/web/.oracle-artifacts/paper-history.csv
# By default, artifacts are gitignored (regenerable). Force-track the
# specific demo bundles so the web build + CI have real, committed numbers
# without needing the 28MB source dataset to regenerate.
apps/api/examples/backtest/artifacts/*
!apps/api/examples/backtest/artifacts/sp500_momentum_126/
!apps/api/examples/backtest/artifacts/sp500_momentum_126_pit/
!apps/api/examples/backtest/artifacts/sp500_momentum_126_2026/
!apps/api/examples/backtest/artifacts/sp500_momentum_sweep/
!apps/api/examples/backtest/artifacts/sp500_momentum_sweep_pit/
!apps/api/examples/backtest/artifacts/sp500_ml_predictions_v1/

# ---- ML trainer derived artifacts ----
# 36MB+ per run (OOF predictions CSV + feature importances + booster).
# Tracked via MLflow rather than git; not committed.
apps/api/examples/ml/artifacts/

# ---- Models (tracked via MLflow) ----
apps/api/models/*.pkl
apps/api/models/*.joblib
apps/api/models/*.onnx
mlruns/
mlflow.db

# ---- Logs ----
logs/
*.log

# ---- Docker volumes (local) ----
.docker-data/
infra/postgres/data/
infra/redis/data/
infra/minio/data/

# ---- IDE ----
.idea/
.vscode/
*.iml

# ---- Test artifacts ----
.pytest_cache/
test-results/
coverage.xml

# ---- Legacy project dirs (pre-monorepo consolidation) ----
Finance_Project/.venv/
Finance_Project/__pycache__/
Finance_Project/.pytest_cache/
ShAuRyA_Finance/node_modules/
ShAuRyA_Finance/.next/
Dataset_Finance/
.codex-pet-runs/
